<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalle de Incidencia"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:id="@+id/txtDTitulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#E0F2FE"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        android:layout_marginBottom="24dp">

                        <TextView
                            android:id="@+id/txtDEstado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="ESTADO"
                            android:textColor="#0284C7"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descripción:"
                        android:textSize="14sp"
                        android:textColor="#6B7280"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/txtDDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="#374151"
                        android:lineSpacingExtra="4dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAsignar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Asignar técnico"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCambiarEstado"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Avanzar Estado"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAvisarCau"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Avisar al CAU (Externo)"
            app:cornerRadius="12dp"
            app:backgroundTint="#EF4444"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Eliminar Incidencia"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#EF4444"
            android:textColor="#EF4444"
            app:cornerRadius="12dp"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>